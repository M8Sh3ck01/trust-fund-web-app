# ════════════════════════════════════════════════════════════════
#  ENV TEMPLATE — Commit this file. DO NOT commit .env
#  Copy to .env and fill in your real values.
#    cp .env.example .env
# ════════════════════════════════════════════════════════════════

NODE_ENV=development
PORT=5000
HOST=0.0.0.0

# ── Google OAuth 2.0 Credentials ─────────────────────────────────
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create an OAuth 2.0 Client ID (Web application)
# 3. Add http://localhost:5000/auth/google/callback as an Authorized Redirect URI
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google/callback

# ── Session ───────────────────────────────────────────────────────
# Generate with: node -e "require('crypto').randomBytes(64).toString('hex') |> console.log"
# Or more simply: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=replace-with-a-128-char-random-hex-string

# ── MongoDB ───────────────────────────────────────────────────────
# Local:  mongodb://127.0.0.1:27017/your_db_name
# Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net/your_db_name
MONGO_URI=mongodb://127.0.0.1:27017/backend_core_dev

# ── Frontend ──────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
